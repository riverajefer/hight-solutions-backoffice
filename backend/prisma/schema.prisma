  @@index([uploadedBy])
  @@index([isDeleted])
  @@map("uploaded_files")
}

// =============================================================================
// MÓDULO DE INFORMACIÓN DE LA COMPAÑÍA
// =============================================================================
// =============================================================================
// MÓDULO DE ÓRDENES DE TRABAJO (OT)
// =============================================================================

enum WorkOrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

enum WorkOrderTimeEntryType {
  HOURS
  RANGE
}

model WorkOrder {
  id              String          @id @default(uuid())
  workOrderNumber String          @unique @map("work_order_number") // "OT-2025-0001"
  orderId         String          @map("order_id")
  advisorId       String          @map("advisor_id")
  designerId      String?         @map("designer_id")
  fileName        String?         @map("file_name") // max 30 chars
  attachmentId    String?         @map("attachment_id")
  attachment2Id   String?         @map("attachment2_id")
  observations    String?
  status          WorkOrderStatus @default(DRAFT)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  order            Order                @relation(fields: [orderId], references: [id])
  advisor          User                 @relation("WorkOrderAdvisor", fields: [advisorId], references: [id])
  designer         User?                @relation("WorkOrderDesigner", fields: [designerId], references: [id])
  attachment       UploadedFile?        @relation("WorkOrderAttachment1", fields: [attachmentId], references: [id])
  attachment2      UploadedFile?        @relation("WorkOrderAttachment2", fields: [attachment2Id], references: [id])
  items            WorkOrderItem[]
  timeEntries      WorkOrderTimeEntry[]
  expenseOrders    ExpenseOrder[]
  productionOrders ProductionOrder[]

  @@index([orderId])
  @@index([advisorId])
  @@index([status])
  @@map("work_orders")
}

model WorkOrderItem {
  id                 String   @id @default(uuid())
  workOrderId        String   @map("work_order_id")
  orderItemId        String   @map("order_item_id")
  productDescription String   @map("product_description")
  observations       String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  workOrder       WorkOrder                     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  orderItem       OrderItem                     @relation(fields: [orderItemId], references: [id])
  productionAreas WorkOrderItemProductionArea[]
  supplies        WorkOrderItemSupply[]
  timeEntries     WorkOrderTimeEntry[]

  @@index([workOrderId])
  @@index([orderItemId])
  @@map("work_order_items")
}

model WorkOrderItemProductionArea {
  workOrderItemId  String
  productionAreaId String
  assignedAt       DateTime @default(now()) @map("assigned_at")

  workOrderItem  WorkOrderItem  @relation(fields: [workOrderItemId], references: [id], onDelete: Cascade)
  productionArea ProductionArea @relation(fields: [productionAreaId], references: [id], onDelete: Cascade)

  @@id([workOrderItemId, productionAreaId])
  @@map("work_order_item_production_areas")
}

model WorkOrderItemSupply {
  id              String   @id @default(uuid())
  workOrderItemId String   @map("work_order_item_id")
  supplyId        String   @map("supply_id")
  quantity        Decimal?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  workOrderItem WorkOrderItem @relation(fields: [workOrderItemId], references: [id], onDelete: Cascade)
  supply        Supply        @relation(fields: [supplyId], references: [id])

  @@unique([workOrderItemId, supplyId])
  @@index([workOrderItemId])
  @@index([supplyId])
  @@map("work_order_item_supplies")
}

model WorkOrderTimeEntry {
  id              String                 @id @default(uuid())
  workOrderId     String                 @map("work_order_id")
  workOrderItemId String?                @map("work_order_item_id")
  userId          String                 @map("user_id")
  entryType       WorkOrderTimeEntryType @map("entry_type")
  workedDate      DateTime               @map("worked_date")
  hoursWorked     Decimal                @map("hours_worked")
  startAt         DateTime?              @map("start_at")
  endAt           DateTime?              @map("end_at")
  notes           String?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  workOrder     WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workOrderItem WorkOrderItem? @relation(fields: [workOrderItemId], references: [id], onDelete: SetNull)
  user          User           @relation("WorkOrderTimeEntryUser", fields: [userId], references: [id])

  @@index([workOrderId])
  @@index([workOrderItemId])
  @@index([userId])
  @@index([workedDate])
  @@map("work_order_time_entries")
}

// =============================================================================
// MÓDULO DE ÓRDENES DE GASTOS (OG)
// =============================================================================

enum ExpenseOrderStatus {
  DRAFT // Borrador (editable)
  CREATED // Creada
  ADMIN_AUTHORIZED // Pre-autorizada por Admin (pendiente de Caja)
  AUTHORIZED // Autorizada por Caja (registra pago)
  PAID // Pagada
}

model ExpenseType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subcategories ExpenseSubcategory[]
  expenseOrders ExpenseOrder[]
  accountsPayable AccountPayable[]

  @@map("expense_types")
}

model ExpenseSubcategory {
  id            String   @id @default(uuid())
  name          String
  description   String?
  expenseTypeId String   @map("expense_type_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  expenseType   ExpenseType    @relation(fields: [expenseTypeId], references: [id])
  expenseOrders ExpenseOrder[]
  accountsPayable AccountPayable[]

  @@unique([name, expenseTypeId])
  @@map("expense_subcategories")
}

model ExpenseOrder {
  id                   String             @id @default(uuid())
  ogNumber             String             @unique @map("og_number") // "OG-2026-001"
  expenseTypeId        String             @map("expense_type_id")
  expenseSubcategoryId String             @map("expense_subcategory_id")
  workOrderId          String?            @map("work_order_id") // Opcional: OT asociada
  authorizedToId       String             @map("authorized_to_id") // Usuario autorizado
  responsibleId        String?            @map("responsible_id") // Responsable (opcional)
  observations         String?
  areaOrMachine        String?            @map("area_or_machine")
  status               ExpenseOrderStatus @default(DRAFT)

  // Auditoría
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Primera autorización Admin (quién aprobó el cambio a ADMIN_AUTHORIZED)
  authorizedById String?   @map("authorized_by_id")
  authorizedAt   DateTime? @map("authorized_at")

  // Segunda autorización Caja (quién aprobó el cambio a AUTHORIZED y registró el pago)
  cajaAuthorizedById String?   @map("caja_authorized_by_id")
  cajaAuthorizedAt   DateTime? @map("caja_authorized_at")

  // Relaciones
  expenseType        ExpenseType               @relation(fields: [expenseTypeId], references: [id])
  expenseSubcategory ExpenseSubcategory        @relation(fields: [expenseSubcategoryId], references: [id])
  workOrder          WorkOrder?                @relation(fields: [workOrderId], references: [id])
  authorizedTo       User                      @relation("AuthorizedExpenseOrders", fields: [authorizedToId], references: [id])
  responsible        User?                     @relation("ResponsibleExpenseOrders", fields: [responsibleId], references: [id])
  createdBy          User                      @relation("CreatedExpenseOrders", fields: [createdById], references: [id])
  authorizedBy       User?                     @relation("ApprovedExpenseOrders", fields: [authorizedById], references: [id])
  cajaAuthorizedBy   User?                     @relation("CajaAuthorizedExpenseOrders", fields: [cajaAuthorizedById], references: [id])
  items              ExpenseOrderItem[]
  authRequests       ExpenseOrderAuthRequest[]
  accountPayable     AccountPayable?

  @@index([status])
  @@index([workOrderId])
  @@index([createdById])
  @@index([createdAt])
  @@map("expense_orders")
}

model ExpenseOrderItem {
  id              String        @id @default(uuid())
  expenseOrderId  String        @map("expense_order_id")
  quantity        Decimal
  name            String // Nombre del gasto
  description     String?
  supplierId      String?       @map("supplier_id") // Proveedor (opcional)
  unitPrice       Decimal       @map("unit_price")
  total           Decimal // quantity * unitPrice
  paymentMethod   PaymentMethod @default(CASH) @map("payment_method")
  receiptFileId   String?       @map("receipt_file_id") // Comprobante de pago
  referenceFileId String?       @map("reference_file_id") // Imagen de referencia

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  expenseOrder    ExpenseOrder                     @relation(fields: [expenseOrderId], references: [id], onDelete: Cascade)
  supplier        Supplier?                        @relation(fields: [supplierId], references: [id])
  productionAreas ExpenseOrderItemProductionArea[]

  @@index([expenseOrderId])
  @@map("expense_order_items")
}

model ExpenseOrderItemProductionArea {
  expenseOrderItemId String
  productionAreaId   String
  assignedAt         DateTime @default(now()) @map("assigned_at")

  expenseOrderItem ExpenseOrderItem @relation(fields: [expenseOrderItemId], references: [id], onDelete: Cascade)
  productionArea   ProductionArea   @relation(fields: [productionAreaId], references: [id], onDelete: Cascade)

  @@id([expenseOrderItemId, productionAreaId])
  @@map("expense_order_item_production_areas")
}

model ExpenseOrderAuthRequest {
  id             String            @id @default(uuid())
  expenseOrderId String            @map("expense_order_id")
  requestedById  String            @map("requested_by_id")
  reason         String?
  status         EditRequestStatus @default(PENDING)
  reviewedById   String?           @map("reviewed_by_id")
  reviewedAt     DateTime?         @map("reviewed_at")
  reviewNotes    String?           @map("review_notes")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  expenseOrder ExpenseOrder @relation(fields: [expenseOrderId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("RequestedExpenseOrderAuthRequests", fields: [requestedById], references: [id])
  reviewedBy   User?        @relation("ReviewedExpenseOrderAuthRequests", fields: [reviewedById], references: [id])

  @@index([expenseOrderId])
  @@index([requestedById])
  @@index([status])
  @@map("expense_order_auth_requests")
}

// =============================================================================
// MÓDULO DE APROBACIÓN DE ANTICIPOS
