  INACTIVE
}

enum ContractType {
  FIXED_TERM
  INDEFINITE
  SERVICE_CONTRACT
  INTERNSHIP
}

enum PayrollPeriodType {
  BIWEEKLY
  MONTHLY
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATED
  PAID
}

model Employee {
  id            String         @id @default(uuid())
  userId        String         @unique
  cargoId       String?
  employeeType  EmployeeType   @default(REGULAR)
  monthlySalary Decimal?       @db.Decimal(12, 2)
  dailyRate     Decimal?       @db.Decimal(12, 2)
  startDate     DateTime
  contractType  ContractType?
  status        EmployeeStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  cargo        Cargo?        @relation(fields: [cargoId], references: [id])
  payrollItems PayrollItem[]

  @@map("employees")
}

model PayrollPeriod {
  id                    String              @id @default(uuid())
  name                  String
  startDate             DateTime
  endDate               DateTime
  periodType            PayrollPeriodType
  status                PayrollPeriodStatus @default(DRAFT)
  overtimeDaytimeRate   Decimal?            @db.Decimal(10, 2)
  overtimeNighttimeRate Decimal?            @db.Decimal(10, 2)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  payrollItems PayrollItem[]

  @@map("payroll_periods")
}

model PayrollItem {
  id                     String   @id @default(uuid())
  periodId               String
  employeeId             String
  daysWorked             Decimal? @db.Decimal(5, 2)
  baseSalary             Decimal  @db.Decimal(12, 2)
  overtimeDaytimeHours   Decimal? @db.Decimal(7, 2)
  overtimeNighttimeHours Decimal? @db.Decimal(7, 2)
  overtimeDaytimeValue   Decimal? @db.Decimal(12, 2)
  overtimeNighttimeValue Decimal? @db.Decimal(12, 2)
  commissions            Decimal? @db.Decimal(12, 2)
  restDayValue           Decimal? @db.Decimal(12, 2)
  transportAllowance     Decimal? @db.Decimal(12, 2)
  workdayDiscount        Decimal? @db.Decimal(12, 2)
  loans                  Decimal? @db.Decimal(12, 2)
  advances               Decimal? @db.Decimal(12, 2)
  nonPaidDays            Decimal? @db.Decimal(12, 2)
  epsAndPensionDiscount  Decimal? @db.Decimal(12, 2)
  totalPayment           Decimal  @db.Decimal(12, 2)
  observations           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  period   PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id])

  @@unique([periodId, employeeId])
  @@map("payroll_items")
}

// ──────────────────────────────────────────
//  Attendance & Time Control
// ──────────────────────────────────────────

enum AttendanceType {
  MANUAL
  AUTO
}

enum AttendanceSource {
  BUTTON
  INACTIVITY
  LOGOUT
  SYSTEM
}

model AttendanceRecord {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  date         DateTime         @db.Date
  clockIn      DateTime         @map("clock_in")
  clockOut     DateTime?        @map("clock_out")
  type         AttendanceType   @default(MANUAL)
  source       AttendanceSource @default(BUTTON)
  notes        String?
  totalMinutes Int?             @map("total_minutes")
  metadata     Json?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("attendance_records")
}

model ActivityHeartbeat {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  timestamp DateTime @default(now())
  endpoint  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("activity_heartbeats")
}

// =============================================================================
// MÓDULO DE INVENTARIO - MOVIMIENTOS DE INSUMOS
// =============================================================================

enum InventoryMovementType {
  ENTRY // Entrada de stock (compra, recepción)
  EXIT // Salida de stock (consumo en OT - automático)
  ADJUSTMENT // Ajuste manual (conteo físico, corrección)
  RETURN // Devolución al stock desde producción
  INITIAL // Carga inicial de stock
}

model InventoryMovement {
  id            String                @id @default(uuid())
  supplyId      String                @map("supply_id")
  type          InventoryMovementType
  quantity      Decimal // Siempre positivo; la dirección la determina el tipo
  unitCost      Decimal?              @map("unit_cost") // Costo unitario en el momento del movimiento
  previousStock Decimal               @map("previous_stock")
  newStock      Decimal               @map("new_stock")
  referenceType String?               @map("reference_type") // "WORK_ORDER", "MANUAL", "INITIAL"
  referenceId   String?               @map("reference_id")
  reason        String? // Motivo del ajuste
  notes         String?
  performedById String                @map("performed_by_id")
  createdAt     DateTime              @default(now()) @map("created_at")

  supply      Supply @relation(fields: [supplyId], references: [id])
  performedBy User   @relation(fields: [performedById], references: [id])

  @@index([supplyId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("inventory_movements")
}

// =============================================================================
// MÓDULO DE PRODUCCIÓN - PLANTILLAS Y ÓRDENES DE PRODUCCIÓN
// =============================================================================

enum ComponentPhase {
  impresion
  material
  armado
  despacho
}

enum ProductionOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  BLOCKED
}

// Catálogo de tipos de paso de producción (dinámico — convention: UPPERCASE_SNAKE_CASE)
model StepDefinition {
  id          String   @id @default(uuid())
  type        String   @unique // Convention: UPPERCASE_SNAKE_CASE (e.g. PAPEL, BARNIZADO_UV)
  name        String
  description String?
  fieldSchema Json     @map("field_schema") // { fields: [{ key, label, type, stage, required, options? }] }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  templateComponentSteps TemplateComponentStep[]
  productionOrderSteps   ProductionOrderStep[]

  @@map("step_definitions")
}

// Plantilla de producto (Cuaderno, Carpeta, Revista, Talonario, etc.)
model ProductTemplate {
  id          String   @id @default(uuid())
  name        String
  category    String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  components       TemplateComponent[]
  productionOrders ProductionOrder[]

  @@map("product_templates")
}

// Componente dentro de una plantilla (Portadas, Hojas internas, Armado, Empaque, etc.)
model TemplateComponent {
  id         String         @id @default(uuid())
  templateId String         @map("template_id")
  name       String
  order      Int
  isRequired Boolean        @default(true) @map("is_required")
  phase      ComponentPhase
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  template ProductTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  steps    TemplateComponentStep[]

  @@index([templateId])
  @@map("template_components")
}

// Paso dentro de un componente de plantilla (con posibilidad de fieldOverrides)
model TemplateComponentStep {
  id               String   @id @default(uuid())
  componentId      String   @map("component_id")
  stepDefinitionId String   @map("step_definition_id")
  order            Int
  isRequired       Boolean  @default(true) @map("is_required")
  fieldOverrides   Json?    @map("field_overrides") // { remove: [...], add: [...], override: [...] }
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  component      TemplateComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  stepDefinition StepDefinition    @relation(fields: [stepDefinitionId], references: [id])

  @@index([componentId])
  @@map("template_component_steps")
}

// Orden de producción instanciada desde una plantilla (1:N con WorkOrder)
model ProductionOrder {
  id          String                @id @default(uuid())
  oprodNumber String                @unique @map("oprod_number") // "OPROD-2026-0001"
  templateId  String                @map("template_id")
  workOrderId String                @map("work_order_id")
  status      ProductionOrderStatus @default(PENDING)
  notes       String?
  createdById String                @map("created_by_id")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  template   ProductTemplate            @relation(fields: [templateId], references: [id])
  workOrder  WorkOrder                  @relation(fields: [workOrderId], references: [id])
  createdBy  User                       @relation("ProductionOrderCreatedBy", fields: [createdById], references: [id])
  components ProductionOrderComponent[]

  @@index([workOrderId])
  @@index([status])
  @@index([createdById])
  @@map("production_orders")
}

// Copia instanciada de cada TemplateComponent para una OT específica
model ProductionOrderComponent {
  id                String         @id @default(uuid())
  productionOrderId String         @map("production_order_id")
  name              String
  order             Int
  phase             ComponentPhase
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  productionOrder ProductionOrder       @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  steps           ProductionOrderStep[]

  @@index([productionOrderId])
  @@map("production_order_components")
}

// Copia instanciada de cada paso con su estado y valores llenados
model ProductionOrderStep {
  id               String               @id @default(uuid())
  componentId      String               @map("component_id")
  stepDefinitionId String               @map("step_definition_id")
  order            Int
  status           ProductionStepStatus @default(PENDING)
  fieldValues      Json                 @default("{}") @map("field_values") // { specification: {}, execution: {} }
  completedAt      DateTime?            @map("completed_at")
  completedById    String?              @map("completed_by_id")
  notes            String?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  component      ProductionOrderComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  stepDefinition StepDefinition           @relation(fields: [stepDefinitionId], references: [id])
  completedBy    User?                    @relation("ProductionStepCompletedBy", fields: [completedById], references: [id])

  @@index([componentId])
  @@index([status])
  @@map("production_order_steps")
}

// =============================================================================
// MÓDULO DE COMENTARIOS — Comentarios Polimórficos
// =============================================================================

enum CommentEntityType {
  QUOTE
  ORDER
  WORK_ORDER
}

model Comment {
  id         String            @id @default(uuid())
  content    String
  entityType CommentEntityType @map("entity_type")
  entityId   String            @map("entity_id")
  authorId   String            @map("author_id")
  parentId   String?           @map("parent_id")
  deletedAt  DateTime?         @map("deleted_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  author  User      @relation("CommentAuthor", fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([entityType, entityId])
  @@index([parentId])
  @@map("comments")
}

// =============================================================================
// MÓDULO DE CAJA REGISTRADORA (POS)
// =============================================================================

model CashRegister {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions CashSession[]

  @@map("cash_registers")
}

model CashSession {
  id             String            @id @default(uuid())
  cashRegisterId String            @map("cash_register_id")
  openedById     String            @map("opened_by_id")
  closedById     String?           @map("closed_by_id")
  status         CashSessionStatus @default(OPEN)
  openingAmount  Decimal           @map("opening_amount")
  closingAmount  Decimal?          @map("closing_amount")
  systemBalance  Decimal?          @map("system_balance")
  discrepancy    Decimal?
  notes          String?
  openedAt       DateTime          @default(now()) @map("opened_at")
  closedAt       DateTime?         @map("closed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  cashRegister  CashRegister            @relation(fields: [cashRegisterId], references: [id])
  openedBy      User                    @relation("OpenedCashSessions", fields: [openedById], references: [id])
  closedBy      User?                   @relation("ClosedCashSessions", fields: [closedById], references: [id])
  denominations CashDenominationCount[]
  movements     CashMovement[]

  @@index([cashRegisterId, status])
  @@index([openedById])
  @@index([openedAt])
  @@map("cash_sessions")
}

model CashDenominationCount {
  id            String                @id @default(uuid())
  cashSessionId String                @map("cash_session_id")
  countType     DenominationCountType @map("count_type")
  denomType     DenominationType      @map("denom_type")
  denomination  Int
  quantity      Int
  subtotal      Decimal

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@unique([cashSessionId, countType, denomination])
  @@index([cashSessionId, countType])
  @@map("cash_denomination_counts")
}

model CashMovement {
  id                String           @id @default(uuid())
  cashSessionId     String           @map("cash_session_id")
  receiptNumber     String           @unique @map("receipt_number")
  movementType      CashMovementType @map("movement_type")
  paymentMethod     PaymentMethod    @default(CASH) @map("payment_method")
  amount            Decimal
  description       String
  referenceType     String?          @map("reference_type")
  referenceId       String?          @map("reference_id")
  isVoided          Boolean          @default(false) @map("is_voided")
  voidedById        String?          @map("voided_by_id")
  voidedAt          DateTime?        @map("voided_at")
  voidReason        String?          @map("void_reason")
  counterMovementId String?          @unique @map("counter_movement_id")
  performedById     String           @map("performed_by_id")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  cashSession           CashSession               @relation(fields: [cashSessionId], references: [id])
  performedBy           User                      @relation("PerformedCashMovements", fields: [performedById], references: [id])
  voidedBy              User?                     @relation("VoidedCashMovements", fields: [voidedById], references: [id])
  counterMovement       CashMovement?             @relation("CounterMovement", fields: [counterMovementId], references: [id])
  originalMovement      CashMovement?             @relation("CounterMovement")
  linkedPayment         Payment?
  voidRequests          CashMovementVoidRequest[]
  refundRequest         RefundRequest?
  accountPayablePayment AccountPayablePayment?

  @@index([cashSessionId])
  @@index([performedById])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("cash_movements")
}

model CashMovementVoidRequest {
  id             String            @id @default(uuid())
  cashMovementId String            @map("cash_movement_id")
  requestedById  String            @map("requested_by_id")
  voidReason     String            @map("void_reason")
  status         EditRequestStatus @default(PENDING)

  // Aprobación/rechazo
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNotes  String?   @map("review_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("RequestedVoidRequests", fields: [requestedById], references: [id])
  reviewedBy   User?        @relation("ReviewedVoidRequests", fields: [reviewedById], references: [id])

  @@index([cashMovementId])
  @@index([requestedById])
  @@index([status])
  @@map("cash_movement_void_requests")
}

// =============================================================================
// MÓDULO DE SOLICITUDES DE DEVOLUCIÓN DE DINERO AL CLIENTE
// =============================================================================

model RefundRequest {
  id            String            @id @default(uuid())
  orderId       String            @map("order_id")
  refundAmount  Decimal           @map("refund_amount")
  paymentMethod PaymentMethod     @map("payment_method")
  observation   String
  status        EditRequestStatus @default(PENDING)

  // Solicitante
  requestedById String   @map("requested_by_id")
  requestedAt   DateTime @default(now()) @map("requested_at")

  // Revisión
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNotes  String?   @map("review_notes")

  // Ejecución (al aprobar)
  executedAt     DateTime? @map("executed_at")
  cashMovementId String?   @unique @map("cash_movement_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy  User          @relation("RequestedRefundRequests", fields: [requestedById], references: [id])
  reviewedBy   User?         @relation("ReviewedRefundRequests", fields: [reviewedById], references: [id])
  cashMovement CashMovement? @relation(fields: [cashMovementId], references: [id])

  @@index([orderId])
  @@index([requestedById])
  @@index([status])
  @@map("refund_requests")
}

// =============================================================================
// MÓDULO DE CUENTAS POR PAGAR
// =============================================================================

enum AccountPayableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum RecurringFrequency {
  BIWEEKLY
  MONTHLY
  SEMIANNUAL
  ANNUAL
}

model AccountPayable {
  id           String               @id @default(uuid())
  apNumber     String               @unique @map("ap_number")
  expenseTypeId        String       @map("expense_type_id")
  expenseSubcategoryId String       @map("expense_subcategory_id")
  status       AccountPayableStatus @default(PENDING)
  description  String
  observations String?
  totalAmount  Decimal              @map("total_amount") @db.Decimal(12, 2)
  paidAmount   Decimal              @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balance      Decimal              @map("balance") @db.Decimal(12, 2)
  dueDate      DateTime             @map("due_date")
  isRecurring        Boolean              @default(false) @map("is_recurring")
  recurringDay       Int?                 @map("recurring_day")
  recurringFrequency RecurringFrequency?  @map("recurring_frequency")

  supplierId     String? @map("supplier_id")
  expenseOrderId String? @unique @map("expense_order_id")

  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById String?   @map("cancelled_by_id")
  cancelReason  String?   @map("cancel_reason")

  expenseType        ExpenseType        @relation(fields: [expenseTypeId], references: [id])
  expenseSubcategory ExpenseSubcategory @relation(fields: [expenseSubcategoryId], references: [id])
  supplier     Supplier?                   @relation(fields: [supplierId], references: [id])
  expenseOrder ExpenseOrder?               @relation(fields: [expenseOrderId], references: [id])
  createdBy    User                        @relation("AccountPayableCreatedBy", fields: [createdById], references: [id])
  cancelledBy  User?                       @relation("AccountPayableCancelledBy", fields: [cancelledById], references: [id])
  payments     AccountPayablePayment[]
  attachments  AccountPayableAttachment[]
  installments AccountPayableInstallment[]

  @@index([status])
  @@index([dueDate])
  @@index([supplierId])
  @@index([createdById])
  @@index([createdAt])
  @@map("accounts_payable")
}

model AccountPayablePayment {
  id               String        @id @default(uuid())
  accountPayableId String        @map("account_payable_id")
  amount           Decimal       @db.Decimal(12, 2)
  paymentMethod    PaymentMethod @default(CASH) @map("payment_method")
  reference        String?
  notes            String?
  receiptFileId    String?       @map("receipt_file_id")
  cashMovementId   String?       @unique @map("cash_movement_id")

  registeredById String   @map("registered_by_id")
  paymentDate    DateTime @map("payment_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  accountPayable AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  cashMovement   CashMovement?  @relation(fields: [cashMovementId], references: [id])
  registeredBy   User           @relation("AccountPayablePaymentRegisteredBy", fields: [registeredById], references: [id])

  @@index([accountPayableId])
  @@index([paymentDate])
  @@map("account_payable_payments")
}

model AccountPayableAttachment {
  id               String   @id @default(uuid())
  accountPayableId String   @map("account_payable_id")
  fileUrl          String   @map("file_url")
  fileName         String   @map("file_name")
  fileType         String?  @map("file_type")
  uploadedById     String   @map("uploaded_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  accountPayable AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation("AccountPayableAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([accountPayableId])
  @@map("account_payable_attachments")
}

model AccountPayableInstallment {
  id                String    @id @default(uuid())
  accountPayableId  String    @map("account_payable_id")
  installmentNumber Int       @map("installment_number")
  amount            Decimal   @db.Decimal(12, 2)
  dueDate           DateTime  @map("due_date")
  isPaid            Boolean   @default(false) @map("is_paid")
  paidAt            DateTime? @map("paid_at")
  paidById          String?   @map("paid_by_id")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  accountPayable AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  paidBy         User?          @relation("InstallmentPaidBy", fields: [paidById], references: [id])

  @@index([accountPayableId])
  @@map("account_payable_installments")
}
