generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  username           String?  @unique
  email              String?  @unique
  password           String
  refreshToken       String?
  roleId             String
  cargoId            String?
  profilePhoto       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  firstName          String?
  lastName           String?
  phone              String?
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)

  role                                 Role                         @relation(fields: [roleId], references: [id])
  cargo                                Cargo?                       @relation(fields: [cargoId], references: [id])
  sessionLogs                          SessionLog[]
  createdOrders                        Order[]
  receivedPayments                     Payment[]                    @relation("ReceivedPayments")
  requestedEditRequests                OrderEditRequest[]           @relation("RequestedEditRequests")
  reviewedEditRequests                 OrderEditRequest[]           @relation("ReviewedEditRequests")
  requestedStatusChangeRequests        OrderStatusChangeRequest[]   @relation("RequestedStatusChangeRequests")
  reviewedStatusChangeRequests         OrderStatusChangeRequest[]   @relation("ReviewedStatusChangeRequests")
  notifications                        Notification[]
  createdQuotes                        Quote[]
  appliedDiscounts                     OrderDiscount[]              @relation("AppliedDiscounts")
  advisedWorkOrders                    WorkOrder[]                  @relation("WorkOrderAdvisor")
  designedWorkOrders                   WorkOrder[]                  @relation("WorkOrderDesigner")
  workOrderTimeEntries                 WorkOrderTimeEntry[]         @relation("WorkOrderTimeEntryUser")
  authorizedExpenseOrders              ExpenseOrder[]               @relation("AuthorizedExpenseOrders")
  cajaAuthorizedExpenseOrders          ExpenseOrder[]               @relation("CajaAuthorizedExpenseOrders")
  responsibleExpenseOrders             ExpenseOrder[]               @relation("ResponsibleExpenseOrders")
  createdExpenseOrders                 ExpenseOrder[]               @relation("CreatedExpenseOrders")
  approvedExpenseOrders                ExpenseOrder[]               @relation("ApprovedExpenseOrders")
  requestedExpenseOrderAuthRequests    ExpenseOrderAuthRequest[]    @relation("RequestedExpenseOrderAuthRequests")
  reviewedExpenseOrderAuthRequests     ExpenseOrderAuthRequest[]    @relation("ReviewedExpenseOrderAuthRequests")
  requestedAdvancePaymentApprovals     AdvancePaymentApproval[]     @relation("RequestedAdvancePaymentApprovals")
  reviewedAdvancePaymentApprovals      AdvancePaymentApproval[]     @relation("ReviewedAdvancePaymentApprovals")
  discountApprovalRequests             DiscountApproval[]           @relation("DiscountApprovalRequests")
  discountApprovalReviews              DiscountApproval[]           @relation("DiscountApprovalReviews")
  advisedClients                       Client[]                     @relation("ClientAdvisor")
  requestedClientOwnershipAuthRequests ClientOwnershipAuthRequest[] @relation("RequestedClientOwnershipAuthRequests")
  advisedClientOwnershipAuthRequests   ClientOwnershipAuthRequest[] @relation("AdvisedClientOwnershipAuthRequests")
  reviewedClientOwnershipAuthRequests  ClientOwnershipAuthRequest[] @relation("ReviewedClientOwnershipAuthRequests")
  payrollEmployee                      Employee?
  attendanceRecords                    AttendanceRecord[]
  activityHeartbeats                   ActivityHeartbeat[]
  inventoryMovements                   InventoryMovement[]
  productionOrdersCreated              ProductionOrder[]            @relation("ProductionOrderCreatedBy")
  productionStepsCompleted             ProductionOrderStep[]        @relation("ProductionStepCompletedBy")
  authoredComments                     Comment[]                    @relation("CommentAuthor")
  // Caja Registradora
  openedCashSessions                   CashSession[]                @relation("OpenedCashSessions")
  closedCashSessions                   CashSession[]                @relation("ClosedCashSessions")
  performedCashMovements               CashMovement[]               @relation("PerformedCashMovements")
  voidedCashMovements                  CashMovement[]               @relation("VoidedCashMovements")
  requestedVoidRequests                CashMovementVoidRequest[]    @relation("RequestedVoidRequests")
  reviewedVoidRequests                 CashMovementVoidRequest[]    @relation("ReviewedVoidRequests")
  requestedRefundRequests              RefundRequest[]              @relation("RequestedRefundRequests")
  reviewedRefundRequests               RefundRequest[]              @relation("ReviewedRefundRequests")
  // Cuentas por Pagar
  createdAccountsPayable               AccountPayable[]             @relation("AccountPayableCreatedBy")
  cancelledAccountsPayable             AccountPayable[]             @relation("AccountPayableCancelledBy")
  registeredApPayments                 AccountPayablePayment[]      @relation("AccountPayablePaymentRegisteredBy")
  uploadedApAttachments                AccountPayableAttachment[]   @relation("AccountPayableAttachmentUploadedBy")
  paidInstallments                     AccountPayableInstallment[]  @relation("InstallmentPaidBy")

  @@map("users")
}

model Cargo {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productionAreaId String
  productionArea   ProductionArea @relation(fields: [productionAreaId], references: [id])

  users     User[]
  employees Employee[]

  @@unique([name, productionAreaId])
  @@map("cargos")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  recordId      String   @map("record_id")
  action        String
  model         String
  oldData       Json?    @map("old_data")
  newData       Json?    @map("new_data")
  changedFields Json?    @map("changed_fields")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// =============================================================================
// MÓDULO DE UBICACIONES (Departamentos y Ciudades de Colombia)
// =============================================================================

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cities    City[]
  clients   Client[]
  suppliers Supplier[]

  @@map("departments")
}

model City {
  id           String   @id @default(uuid())
  name         String
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id])
  clients    Client[]
  suppliers  Supplier[]

  @@unique([name, departmentId])
  @@map("cities")
}

// =============================================================================
// MÓDULO DE CLIENTES Y PROVEEDORES
// =============================================================================

enum PersonType {
  NATURAL
  EMPRESA
}

model Client {
  id               String     @id @default(uuid())
  name             String
  manager          String?
  encargado        String?
  phone            String?
  landlinePhone    String?    @map("landline_phone")
  address          String?
  email            String?    @unique
  departmentId     String     @map("department_id")
  cityId           String     @map("city_id")
  personType       PersonType @map("person_type")
  nit              String?
  cedula           String?
  specialCondition String?    @map("special_condition")
  isActive         Boolean    @default(true) @map("is_active")
  advisorId        String?    @map("advisor_id")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id])
  city       City       @relation(fields: [cityId], references: [id])
  advisor    User?      @relation("ClientAdvisor", fields: [advisorId], references: [id])
  orders     Order[]
  quotes     Quote[]

  @@map("clients")
}

model Supplier {
  id            String     @id @default(uuid())
  name          String
  encargado     String?
  phone         String?
  landlinePhone String?    @map("landline_phone")
  address       String?
  email         String?    @unique
  departmentId  String     @map("department_id")
  cityId        String     @map("city_id")
  personType    PersonType @map("person_type")
  nit           String?
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  department        Department         @relation(fields: [departmentId], references: [id])
  city              City               @relation(fields: [cityId], references: [id])
  expenseOrderItems ExpenseOrderItem[]
  accountsPayable   AccountPayable[]

  @@map("suppliers")
}

// =============================================================================
// MÓDULO DE SESSION LOGS (Registros de inicio y cierre de sesión)
// =============================================================================

model SessionLog {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  loginAt   DateTime  @default(now()) @map("login_at")
  logoutAt  DateTime? @map("logout_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@index([logoutAt])
  @@map("session_logs")
}

// =============================================================================
// MÓDULO DE CATÁLOGOS - FASE 1: UNIDADES DE MEDIDA
// =============================================================================

model UnitOfMeasure {
  id           String   @id @default(uuid())
  name         String   @unique
  abbreviation String   @unique
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  suppliesAsPurchase    Supply[] @relation("PurchaseUnit")
  suppliesAsConsumption Supply[] @relation("ConsumptionUnit")

  @@map("units_of_measure")
}

// =============================================================================
// MÓDULO DE CATÁLOGOS - FASE 2: CATEGORÍAS DE PRODUCTOS
// =============================================================================

model ProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_categories")
}

// =============================================================================
// MÓDULO DE CATÁLOGOS - FASE 3: PRODUCTOS
// =============================================================================

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  basePrice   Decimal? @map("base_price")
  priceUnit   String?  @map("price_unit")
  categoryId  String   @map("category_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category   ProductCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  quoteItems QuoteItem[]

  @@unique([name, categoryId])
  @@map("products")
}

// =============================================================================
// MÓDULO DE CATÁLOGOS - FASE 4: CATEGORÍAS DE INSUMOS
// =============================================================================

model SupplyCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  supplies Supply[]

  @@map("supply_categories")
}

// =============================================================================
// MÓDULO DE CATÁLOGOS - FASE 5: INSUMOS
// =============================================================================

model Supply {
  id                String   @id @default(uuid())
  name              String
  sku               String?  @unique
  description       String?
  categoryId        String   @map("category_id")
  purchasePrice     Decimal? @map("purchase_price")
  purchaseUnitId    String   @map("purchase_unit_id")
  consumptionUnitId String   @map("consumption_unit_id")
  conversionFactor  Decimal  @default(1) @map("conversion_factor")
  currentStock      Decimal  @default(0) @map("current_stock")
  minimumStock      Decimal  @default(0) @map("minimum_stock")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  category        SupplyCategory        @relation(fields: [categoryId], references: [id])
  purchaseUnit    UnitOfMeasure         @relation("PurchaseUnit", fields: [purchaseUnitId], references: [id])
  consumptionUnit UnitOfMeasure         @relation("ConsumptionUnit", fields: [consumptionUnitId], references: [id])
  workOrderItems  WorkOrderItemSupply[]
  movements       InventoryMovement[]

  @@unique([name, categoryId])
  @@map("supplies")
}

// =============================================================================
// MÓDULO DE ÓRDENES - FASE 2: CONSECUTIVOS Y ÓRDENES DE PEDIDO
// =============================================================================

enum OrderStatus {
  DRAFT // Borrador (editable)
  CONFIRMED // Confirmada (bloqueada para edición)
  IN_PRODUCTION // En producción
  READY // Lista para entrega
  DELIVERED // Entregada
  DELIVERED_ON_CREDIT // Entregado a crédito
  WARRANTY // Garantía
  PAID // Pagada
  RETURNED // Devuelta
  ANULADO // Anulada (terminal, sin posibilidad de cambio de estado)
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  NO_RESPONSE // Sin respuesta
  CONVERTED
}

model Consecutive {
  id         String   @id @default(uuid())
  type       String   @unique // "ORDER", "PRODUCTION", "EXPENSE", "QUOTE"
  prefix     String // "OP", "PROD", "GAS", "COT"
  year       Int // 2025, 2026, etc.
  lastNumber Int      @default(0) @map("last_number") // Último número generado
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("consecutives")
}

model Order {
  id           String    @id @default(uuid())
  orderNumber  String    @unique @map("order_number") // "OP-2025-0001"
  clientId     String    @map("client_id")
  orderDate    DateTime  @default(now()) @map("order_date")
  deliveryDate DateTime? @map("delivery_date") // Fecha estimada de entrega

  // Auditoría de cambios de fecha de entrega
  previousDeliveryDate  DateTime? @map("previous_delivery_date") // Última fecha de entrega anterior
  deliveryDateReason    String?   @map("delivery_date_reason") // Razón del cambio de fecha
  deliveryDateChangedAt DateTime? @map("delivery_date_changed_at") // Fecha del último cambio
  deliveryDateChangedBy String?   @map("delivery_date_changed_by") // Usuario que cambió la fecha

  // Cálculos financieros
  subtotal           Decimal // Suma de todos los items
  taxRate            Decimal @default(0.19) @map("tax_rate") // IVA 19%
  tax                Decimal // subtotal * taxRate
  retefuenteRate     Decimal @default(0) @map("retefuente_rate") // Retefuente sobre subtotal (e.g., 0.025 = 2.5%)
  reteICARate        Decimal @default(0) @map("rete_ica_rate")   // ReteICA sobre subtotal (e.g., 0.00414 = 0.414%)
  reteIVARate        Decimal @default(0) @map("rete_iva_rate")   // ReteIVA sobre IVA (e.g., 0.15 = 15%)
  discountAmount     Decimal @default(0) @map("discount_amount") // Total de descuentos aplicados
  requiresColorProof Boolean @default(false) @map("requires_color_proof") // ¿Requiere prueba de color?
  colorProofPrice    Decimal @default(0) @map("color_proof_price") // Precio de la prueba de color
  total              Decimal // subtotal - retenciones + tax - reteIVA - discountAmount + colorProofPrice
  paidAmount         Decimal @default(0) @map("paid_amount") // Abonos realizados
  balance            Decimal // total - paidAmount (saldo pendiente)

  // Estado de aprobación del anticipo (null = sin anticipo o auto-aprobado por admin/caja)
  advancePaymentStatus          EditRequestStatus? @map("advance_payment_status")
  advancePaymentRejectedReason  String?            @map("advance_payment_rejected_reason")

  // Estado de aprobación de descuento (null = sin descuento pendiente o auto-aprobado)
  discountApprovalStatus EditRequestStatus? @map("discount_approval_status")

  // Estado de autorización de propiedad de cliente (null = no aplica o autorizado automáticamente)
  clientOwnershipAuthStatus EditRequestStatus? @map("client_ownership_auth_status")

  status OrderStatus @default(DRAFT)
  notes  String? // Observaciones generales

  // Facturación electrónica (solo aplica cuando tax > 0)
  electronicInvoiceNumber String? @map("electronic_invoice_number") // Número de factura electrónica (máx 30 chars)

  // Auditoría
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  client                      Client                       @relation(fields: [clientId], references: [id])
  createdBy                   User                         @relation(fields: [createdById], references: [id])
  commercialChannelId         String?                      @map("commercial_channel_id")
  commercialChannel           CommercialChannel?           @relation(fields: [commercialChannelId], references: [id])
  items                       OrderItem[]
  payments                    Payment[]
  discounts                   OrderDiscount[]
  editRequests                OrderEditRequest[]
  statusChangeRequests        OrderStatusChangeRequest[]
  advancePaymentApprovals     AdvancePaymentApproval[]
  discountApprovals           DiscountApproval[]
  clientOwnershipAuthRequests ClientOwnershipAuthRequest[]
  refundRequests              RefundRequest[]

  // Referencia a la cotización de origen
  quoteId String? @unique @map("quote_id")
  quote   Quote?  @relation("QuoteToOrder")

  workOrders WorkOrder[]

  @@index([clientId])
  @@index([createdById])
  @@index([orderDate])
  @@index([status])
  @@map("orders")
}

model Quote {
  id          String    @id @default(uuid())
  quoteNumber String    @unique @map("quote_number") // "COT-2025-0001"
  clientId    String    @map("client_id")
  quoteDate   DateTime  @default(now()) @map("quote_date")
  validUntil  DateTime? @map("valid_until") // Validez de la cotización

  // Cálculos financieros
  subtotal Decimal
  taxRate  Decimal @default(0.19) @map("tax_rate")
  tax      Decimal
  total    Decimal

  status QuoteStatus @default(DRAFT)
  notes  String?

  // Auditoría
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  client              Client             @relation(fields: [clientId], references: [id])
  createdBy           User               @relation(fields: [createdById], references: [id])
  commercialChannelId String?            @map("commercial_channel_id")
  commercialChannel   CommercialChannel? @relation(fields: [commercialChannelId], references: [id])
  items               QuoteItem[]

  // Referencia a la orden si se convirtió
  orderId String? @unique @map("order_id")
  order   Order?  @relation("QuoteToOrder", fields: [orderId], references: [id])

  @@index([clientId])
  @@index([createdById])
  @@index([quoteDate])
  @@index([status])
  @@map("quotes")
}

model QuoteItem {
  id        String  @id @default(uuid())
  quoteId   String  @map("quote_id")
  productId String? @map("product_id")

  description String
  quantity    Decimal
  unitPrice   Decimal @map("unit_price")
  total       Decimal

  specifications Json?
  sampleImageId  String? @map("sample_image_id") // ID de la imagen de muestra

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quote           Quote                     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product         Product?                  @relation(fields: [productId], references: [id])
  productionAreas QuoteItemProductionArea[]

  @@index([quoteId])
  @@index([productId])
  @@index([sampleImageId])
  @@map("quote_items")
}

model QuoteItemProductionArea {
  quoteItemId      String
  productionAreaId String
  assignedAt       DateTime       @default(now()) @map("assigned_at")
  quoteItem        QuoteItem      @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)
  productionArea   ProductionArea @relation(fields: [productionAreaId], references: [id], onDelete: Cascade)

  @@id([quoteItemId, productionAreaId])
  @@map("quote_item_production_areas")
}

model QuoteKanbanColumn {
  id           String      @id @default(uuid())
  name         String
  color        String      @default("#1976d2")
  displayOrder Int         @default(0) @map("display_order")
  isActive     Boolean     @default(true) @map("is_active")
  mappedStatus QuoteStatus @map("mapped_status")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("quote_kanban_columns")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String? @map("product_id") // Opcional: producto del catálogo

  // Datos del item
  description String // Descripción del servicio/producto
  quantity    Decimal // Cantidad
  unitPrice   Decimal @map("unit_price") // Precio unitario
  total       Decimal // quantity * unitPrice

  // Especificaciones técnicas (JSON flexible)
  specifications Json? // { color: "rojo", material: "acero", dimensiones: "10x20" }
  sampleImageId  String? @map("sample_image_id") // ID de la imagen de muestra

  sortOrder Int      @default(0) @map("sort_order") // Orden de visualización
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?                  @relation(fields: [productId], references: [id])
  productionAreas OrderItemProductionArea[]
  workOrderItems  WorkOrderItem[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemProductionArea {
  orderItemId      String
  productionAreaId String
  assignedAt       DateTime       @default(now()) @map("assigned_at")
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  productionArea   ProductionArea @relation(fields: [productionAreaId], references: [id], onDelete: Cascade)

  @@id([orderItemId, productionAreaId])
  @@map("order_item_production_areas")
}

enum PaymentMethod {
  CASH // Efectivo
  TRANSFER // Transferencia bancaria
  CARD // Tarjeta de crédito/débito
  CHECK // Cheque
  CREDIT // Crédito
  OTHER // Otro método
  CREDIT_BALANCE // Saldo a favor
}

// Enums del módulo de Caja Registradora
enum CashSessionStatus {
  OPEN // Sesión abierta (en curso)
  CLOSED // Sesión cerrada
}

enum DenominationCountType {
  OPENING // Conteo de apertura
  CLOSING // Conteo de cierre
}

enum DenominationType {
  BILL // Billete
  COIN // Moneda
}

enum CashMovementType {
  INCOME // Ingreso (ej. pago de cliente, abono a OP)
  EXPENSE // Egreso (ej. gasto operativo, pago a proveedor)
  WITHDRAWAL // Retiro de efectivo (a caja fuerte / banco) — movimiento interno
  DEPOSIT // Depósito de efectivo adicional a la caja
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  amount        Decimal // Monto del pago
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  paymentDate   DateTime      @default(now()) @map("payment_date")
  reference     String? // Número de referencia/comprobante
  notes         String? // Observaciones del pago
  receiptFileId String?       @map("receipt_file_id") // ID del archivo de comprobante (relación con UploadedFile)

  // Auditoría
  receivedById String   @map("received_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Vínculo opcional con movimiento de caja
  cashMovementId String? @unique @map("cash_movement_id")

  // Relaciones
  order                  Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  receivedBy             User                    @relation("ReceivedPayments", fields: [receivedById], references: [id])
  advancePaymentApproval AdvancePaymentApproval?
  cashMovement           CashMovement?           @relation(fields: [cashMovementId], references: [id])

  @@index([orderId])
  @@index([receivedById])
  @@index([paymentDate])
  @@index([receiptFileId])
  @@map("payments")
}

model OrderDiscount {
  id      String  @id @default(uuid())
  orderId String  @map("order_id")
  amount  Decimal // Monto del descuento
  reason  String // Motivo/razón del descuento (obligatorio)

  // Auditoría
  appliedById String   @map("applied_by_id")
  appliedAt   DateTime @default(now()) @map("applied_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  appliedBy User               @relation("AppliedDiscounts", fields: [appliedById], references: [id])
  approvals DiscountApproval[]

  @@index([orderId])
  @@index([appliedById])
  @@index([appliedAt])
  @@map("order_discounts")
}

// =============================================================================
// MÓDULO DE SOLICITUDES DE EDICIÓN DE ÓRDENES
// =============================================================================

enum EditRequestStatus {
  PENDING // Pendiente de aprobación
  APPROVED // Aprobada
  REJECTED // Rechazada
  EXPIRED // Expirada (permiso venció)
}

enum ApprovalRequestType {
  ORDER_EDIT
  STATUS_CHANGE
  EXPENSE_ORDER_AUTH
  CLIENT_OWNERSHIP_AUTH
  ADVANCE_PAYMENT
  DISCOUNT_APPROVAL
  CASH_MOVEMENT_VOID
  REFUND_REQUEST
}

enum NotificationType {
  EDIT_REQUEST_PENDING // Nueva solicitud de edición
  EDIT_REQUEST_APPROVED // Solicitud aprobada
  EDIT_REQUEST_REJECTED // Solicitud rechazada
  EDIT_PERMISSION_EXPIRING // Permiso por expirar (1 min antes)
  EDIT_PERMISSION_EXPIRED // Permiso expirado
  STATUS_CHANGE_REQUEST_PENDING // Nueva solicitud de cambio de estado
  STATUS_CHANGE_REQUEST_APPROVED // Solicitud de cambio de estado aprobada
  STATUS_CHANGE_REQUEST_REJECTED // Solicitud de cambio de estado rechazada
  EXPENSE_ORDER_AUTH_REQUEST_PENDING // Nueva solicitud de autorización de OG
  EXPENSE_ORDER_AUTH_REQUEST_APPROVED // Solicitud de autorización de OG aprobada
  EXPENSE_ORDER_AUTH_REQUEST_REJECTED // Solicitud de autorización de OG rechazada
  ADVANCE_PAYMENT_APPROVAL_PENDING // Nueva solicitud de aprobación de anticipo
  ADVANCE_PAYMENT_APPROVAL_APPROVED // Anticipo aprobado
  ADVANCE_PAYMENT_APPROVAL_REJECTED // Anticipo rechazado
  LOW_STOCK_ALERT // Alerta de stock bajo en insumo
  CLIENT_OWNERSHIP_AUTH_PENDING // Nueva solicitud de autorización de propiedad de cliente
  CLIENT_OWNERSHIP_AUTH_APPROVED // Solicitud de autorización aprobada
  CLIENT_OWNERSHIP_AUTH_REJECTED // Solicitud de autorización rechazada
  DISCOUNT_APPROVAL_PENDING // Nueva solicitud de aprobación de descuento
  DISCOUNT_APPROVAL_APPROVED // Descuento aprobado
  DISCOUNT_APPROVAL_REJECTED // Descuento rechazado
  CASH_SESSION_CLOSED_WITH_DISCREPANCY // Sesión de caja cerrada con descuadre
  CASH_LARGE_WITHDRAWAL // Retiro grande de efectivo de caja
  CASH_VOID_REQUEST_PENDING // Nueva solicitud de anulación de movimiento de caja
  CASH_VOID_REQUEST_APPROVED // Solicitud de anulación de movimiento aprobada
  CASH_VOID_REQUEST_REJECTED // Solicitud de anulación de movimiento rechazada
  REFUND_REQUEST_PENDING // Nueva solicitud de devolución de dinero al cliente
  REFUND_REQUEST_APPROVED // Devolución aprobada
  REFUND_REQUEST_REJECTED // Devolución rechazada
}

model EditableOrderStatus {
  id                String      @id @default(uuid())
  orderStatus       OrderStatus @unique @map("order_status")
  allowEditRequests Boolean     @default(true) @map("allow_edit_requests")
  description       String?
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("editable_order_statuses")
}

model OrderEditRequest {
  id            String            @id @default(uuid())
  orderId       String            @map("order_id")
  requestedById String            @map("requested_by_id")
  observations  String?
  status        EditRequestStatus @default(PENDING)

  // Aprobación/rechazo
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNotes  String?   @map("review_notes")

  // Permiso temporal (5 minutos)
  expiresAt DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("RequestedEditRequests", fields: [requestedById], references: [id])
  reviewedBy  User? @relation("ReviewedEditRequests", fields: [reviewedById], references: [id])

  @@index([orderId])
  @@index([requestedById])
  @@index([status])
  @@index([expiresAt])
  @@map("order_edit_requests")
}

// Contexto de acción para botones quick-reply de templates de WhatsApp.
// Vincula el messageId devuelto por Meta con la solicitud correspondiente.
// Se usa para resolver qué requestId aprobar/rechazar cuando el admin toca un botón.
model WhatsappActionContext {
  id          String              @id @default(uuid())
  messageId   String              @unique @map("message_id") // wamid.XXX devuelto por Meta
  requestId   String              @map("request_id") // ID de la solicitud (polimórfico)
  requestType ApprovalRequestType @default(ORDER_EDIT) @map("request_type") // tipo de solicitud
  adminPhone  String              @map("admin_phone") // teléfono normalizado E.164 sin "+"
  expiresAt   DateTime            @map("expires_at") // now + 48h
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([messageId])
  @@index([expiresAt])
  @@map("whatsapp_action_contexts")
}

model OrderStatusChangeRequest {
  id              String            @id @default(uuid())
  orderId         String            @map("order_id")
  requestedById   String            @map("requested_by_id")
  currentStatus   OrderStatus       @map("current_status")
  requestedStatus OrderStatus       @map("requested_status")
  reason          String?
  status          EditRequestStatus @default(PENDING)

  // Aprobación/rechazo
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNotes  String?   @map("review_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("RequestedStatusChangeRequests", fields: [requestedById], references: [id])
  reviewedBy  User? @relation("ReviewedStatusChangeRequests", fields: [reviewedById], references: [id])

  @@index([orderId])
  @@index([requestedById])
  @@index([status])
  @@map("order_status_change_requests")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  message     String
  relatedId   String?          @map("related_id")
  relatedType String?          @map("related_type")
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relación
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

